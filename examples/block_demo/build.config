{
  "formatVersion": 2,
  "buildOptions": {
    "useHMR": true,
    "buildMode": "dev",
    "buildEntry": "main.mjs",
    "scriptEntry": "scripts/index.js",
    "scriptOutput": "scripts/index.js",
    "useJs": true,
    "buildDir": "dev/",
    "dependencies": [
      { "module_name": "@minecraft/server", "version": "2.0.0" },
      { "module_name": "@minecraft/server-ui", "version": "2.0.0" }
    ],
    "resource": {
      "path": "res/",
      "resourceHints": true
    }
  },
  "versionType": "release"
}
